# ── Wix Blog ──────────────────────────────────────────────────────────────────
# manage.wix.com → tu sitio → Configuración → Avanzado → Claves API
WIX_API_KEY=
WIX_SITE_ID=

# ── Facebook ──────────────────────────────────────────────────────────────────
# developers.facebook.com → Graph API Explorer → token de página (largo plazo)
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=

# ── Instagram ─────────────────────────────────────────────────────────────────
# Cuenta Profesional de Instagram vinculada a la página de Facebook
# GET /me/accounts → instagram_business_account.id
INSTAGRAM_USER_ID=
INSTAGRAM_ACCESS_TOKEN=

# ── X (Twitter) ───────────────────────────────────────────────────────────────
# developer.twitter.com → Proyecto → App → Claves y Tokens
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# ── ImgBB (relay de imágenes para Wix e Instagram) ────────────────────────────
# imgbb.com → sección API → Obtener clave
IMGBB_API_KEY=

# ── Configuración general ─────────────────────────────────────────────────────
POSTS_FOLDER=C:\Users\Diario\Desktop\NOTAS AUTOMATICAS
SCHEDULE_HOUR=8
SCHEDULE_MINUTE=0

# Páginas a publicar (números separados por coma). El resto se ignora.
# La página 2 quedó FUERA (no se publica). Horarios por página vía tareas:
#   07:00 → 3,5,7   ·   13:00 → 8,9   (con --pages en cada tarea programada)
ALLOWED_PAGES=3,5,7,8,9

# Orden de presentación en el feed, de ARRIBA hacia abajo (las primeras se leen primero).
# Como en el feed lo último publicado aparece arriba, el sistema publica en orden inverso:
# las páginas que pongas primero acá (3, 5) se publican al final y quedan arriba; deportes
# (8, 9) se publican primero y quedan abajo. Dejá vacío para usar el orden por defecto.
FEED_ORDER=3,5,7,8,9

# ── SEO de las notas de Wix ───────────────────────────────────────────────────
# Cada nota se publica con datos estructurados NewsArticle (Schema.org), Open
# Graph, Twitter Cards y fecha/autor. Esto ayuda a Google Noticias y Discover.
# Nombre del medio (editor/autor) que se pone en los datos estructurados.
SEO_PUBLISHER_NAME=Diario La Campaña
# URL pública del LOGO del diario (PNG/JPG accesible). Recomendado para Google
# Noticias. Si lo dejás vacío, igual funciona pero sin el logo del editor.
SEO_PUBLISHER_LOGO_URL=

# ── Historias (stories) en Instagram + Facebook ───────────────────────────────
# Dirección que se invita a visitar en la historia (texto, sin link clickeable).
STORY_SITE_URL=www.diariolacampaña.com.ar
# En qué redes publicar las historias (separadas por coma).
STORIES_PLATFORMS=instagram,facebook
# Canal de YouTube (Radio del Centro) para las historias de vivo/notas.
YT_CHANNEL_ID=UCqiTJ2oRBLNO1ZzfrdiyjTw
YT_HANDLE=RadiodelCentro
# Títulos a EXCLUIR en las notas de las 13:30 (el programa completo). Separá por coma.
STORY_EXCLUDE_TITLE=MAÑANA DEL CENTRO
# Link del Canal de WhatsApp (para la historia con QR de --canal-story).
CANAL_WSP_URL=https://whatsapp.com/channel/0029Vb81uxu4yltJLzTE611x

# ── Tapa del diario (muro + historia) ─────────────────────────────────────────
# Carpeta donde se deja la foto de la tapa (la misma del PDF). Toma la imagen más nueva.
TAPA_FOLDER=C:\Users\Diario\Desktop\DIARIO PDF

# ── Envío del PDF por mail a clientes ─────────────────────────────────────────
# Cuenta Gmail desde la que se envía y su CONTRASEÑA DE APLICACIÓN (16 caracteres).
# Se genera en myaccount.google.com → Seguridad → Contraseñas de aplicaciones
# (requiere verificación en 2 pasos activada). NO es la contraseña normal de Gmail.
MAIL_FROM=
MAIL_APP_PASSWORD=
MAIL_FROM_NAME=Diario La Campaña
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# Planilla con la columna MAIL y ruta del PDF (si el nombre fijo no existe, toma el más nuevo).
CLIENTES_XLSX=C:\Users\Diario\Desktop\GRUPO CLIENTES PRIVADO\CLIENTES DIARIO DIGITAL.xlsx
MAIL_PDF_PATH=C:\Users\Diario\Desktop\DIARIO PDF\diario_hoy.pdf
MAIL_SUBJECT=Diario La Campaña — Edición de hoy ({fecha})

# ── Farmacias de turno por mail (Colegio de Farmacéuticos) ────────────────────
# Remitente del cronograma mensual (Excel) y los cambios de turno del día.
# Se lee por IMAP de la misma casilla MAIL_FROM con MAIL_APP_PASSWORD.
FARMACIAS_MAIL_FROM=farchivi@gmail.com

# ── Sepelios (--sepelios) ─────────────────────────────────────────────────────
# DESACTIVADOS por pedido del diario: no se publican más (ni Wix, ni FB, ni IG,
# ni historias). La tarea programada de Windows también está deshabilitada.
# Para reactivarlos: poné 1 acá y volvé a habilitar la tarea Sepelios Chivilcoy 2100.
SEPELIOS_ACTIVO=0

# ── Reposteo de publicidad de comercios (--repost) ────────────────────────────
# Cuentas de IG a vigilar; se repostea como historia el post que mencione el
# disparador en el caption. REQUIERE Business Discovery (Acceso Avanzado de
# instagram_basic, App Review de Meta). Hasta entonces, avisa y no hace nada.
REPOST_CUENTAS=almendracafe.chivilcoy,almacendemuebleschivilcoy,solarium.express,inmobiliariapommares,repuestosmartino,capurro.automotores_
REPOST_TRIGGER=@dlcchivilcoy
